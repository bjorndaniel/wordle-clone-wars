{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=WordleCloneWars;Username=postgres;Password=PLACEHOLDER"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithThreadId",
      "WithCorrelationId"
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": ".\\Logs\\WordleCloneWars-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz};{CorrelationId};[{Level:u3}];[T-{ThreadId}];{Message}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "Wordle Clone Wars"
    }
  },
  "AllowedHosts": "*",
  "EmailSettings" : {
    "ApiKey": "#{EMAIL_API_KEY}#",
    "FromName": "Wordle Clone Wars",
    "FromEmail": "#{FROM_EMAIL}#"
  },
  "SyncfusionKey":"#{SYNCFUSION_KEY}#"
}