{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=WordleCloneWars;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithThreadId",
      "WithCorrelationId"
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": ".\\Logs\\WordleCloneWars-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz};{CorrelationId};[{Level:u3}];[T-{ThreadId}];{Message}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "Wordle Clone Wars"
    }
  },
  "AllowedHosts": "*",
  "EmailSettings" : {
    "SmtpHost": "mailcluster.loopia.se",
    "SmtpPort": 587,
    "FromName": "Wordle Clone Wars",
    "FromEmail": "#{FROM_EMAIL}#"
  }
}